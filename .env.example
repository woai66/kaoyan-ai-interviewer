# MySQL 连接串，请改为你的数据库用户、密码和库名
DATABASE_URL="mysql://用户名:密码@localhost:3306/kaoyan_interviewer"

# 大模型 API Key（月之暗面/DeepSeek/OpenAI 等）
OPENAI_API_KEY="your-api-key-here"

# 可选：API 基地址，不填则默认 https://api.moonshot.cn/v1
# OPENAI_BASE_URL="https://api.moonshot.cn/v1"

# 可选：指定哪个邮箱注册后成为管理员；若不填，则首个注册用户自动成为管理员
# ADMIN_EMAIL="admin@example.com"
